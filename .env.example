# Supabase (Frontend – öffentliche Werte, kein Secret)
VITE_SUPABASE_URL=https://<project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-key>

# Optional: nur lokal für Supabase CLI
VITE_SUPABASE_PROJECT_ID=<project-id>

# ─── KI-Schlüssel (nur in Supabase Edge Function Secrets, NICHT im Frontend) ───
#
# OPENAI_API_KEY  → Einfache Parsing-Aufgaben (niedrige Komplexität, keine sensiblen Daten)
#   Verwendet in: parse-time-windows, parse-kunden-text, check-ai-config
#   Beispiel: CSV-Import Tage-Feld, Angehörige-Parsing, Zeitfenster-Erkennung
#
# ANTHROPIC_API_KEY  → Komplexe Aufgaben mit Kontext (hohe Relevanz, Businesslogik)
#   Verwendet in: dashboard-assistant, parse-appointment-text (Dienstplan-KI)
#   Beispiel: Dienstplan-KI, Chat-Assistent, Termin-Vorschläge
#
# Beide Keys werden als Supabase Secrets gesetzt:
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
